SOURCE_CAPTION <- "Source: ACS 5-Year Estimates · TidyTuesday 2025"

EXCLUDE_TERRITORIES <- c("Puerto Rico", "United States Virgin Islands",
                         "Guam", "Commonwealth of the Northern Mariana Islands",
                         "American Samoa")

clean_water <- function(df) {
  df |>
    mutate(
      rate   = percent_lacking_plumbing / 100,
      state  = str_extract(name, "(?<=, ).+$"),
      county = str_remove(name, ",.*$")
    ) |>
    filter(!is.na(rate), !is.na(total_pop), total_pop > 0,
           !state %in% EXCLUDE_TERRITORIES)
}

tuesdata         <- tt_load(2025, week = 4)
water_2023_clean <- clean_water(tuesdata$water_insecurity_2023)
water_2022_clean <- clean_water(tuesdata$water_insecurity_2022)

nat_avg <- mean(water_2023_clean$rate, na.rm = TRUE)
nat_med <- median(water_2023_clean$rate, na.rm = TRUE)
nat_wtd <- sum(water_2023_clean$plumbing, na.rm = TRUE) /
           sum(water_2023_clean$total_pop)

top_counties <- water_2023_clean |>
  arrange(desc(rate)) |> slice_head(n = 10) |>
  select(county, state, total_pop, plumbing, rate)

state_summary <- water_2023_clean |>
  group_by(state) |>
  summarise(
    n_counties    = n(),
    total_pop     = sum(total_pop,  na.rm = TRUE),
    total_lacking = sum(plumbing,   na.rm = TRUE),
    weighted_rate = total_lacking / total_pop,
    .groups = "drop"
  ) |>
  arrange(desc(weighted_rate))

water_change <- water_2022_clean |>
  select(geoid, rate_2022 = rate) |>
  inner_join(
    water_2023_clean |> select(geoid, county, state,
                               rate_2023 = rate, total_pop),
    by = "geoid"
  ) |>
  mutate(change    = rate_2023 - rate_2022,
         direction = if_else(change > 0, "Worsened", "Improved"))

top_changed <- dplyr::bind_rows(
  water_change |> arrange(change)       |> slice_head(n = 5),
  water_change |> arrange(desc(change)) |> slice_head(n = 5)
)

p_bar <- top_changed |>
  ggplot(aes(x = change, y = fct_reorder(county, change),
             fill = direction)) +
  geom_col(width = 0.72) +
  geom_vline(xintercept = 0, linetype = "dashed", color = "grey50") +
  geom_text(aes(label = scales::percent(change, accuracy = 0.01),
                hjust = if_else(change < 0, 1.12, -0.12)),
            size = 3.2, color = "grey20") +
  scale_fill_manual(values = c("Improved" = "#2166ac",
                               "Worsened" = "#d6604d"),
                    guide = "none") +
  scale_x_continuous(labels = scales::percent_format(),
                     expand = expansion(mult = c(0.22, 0.22))) +
  labs(title = "Largest Changes (2022–2023)",
       x = "Change in rate (pp)", y = NULL) +
  theme(panel.grid.major.y = element_blank())

# Why population-weighted rates matter
# A simple average of county rates weights a county of 500 people equally
# to one of 500,000. The population-weighted rate =
# sum_c lacking_c / sum_c pop_c gives the share of the state's total population that lacks plumbing.
