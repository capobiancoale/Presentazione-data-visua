## RQ1: Geographic Distribution {.smaller}

```{r}
#| fig-width: 10
#| fig-height: 5.5

counties_sf <- tigris::counties(cb = TRUE, year = 2023, progress_bar = FALSE) |>
  sf::st_transform(crs = 4326)

states_sf <- tigris::states(cb = TRUE, year = 2023, progress_bar = FALSE) |>
  filter(!STUSPS %in% c("PR", "VI", "GU", "MP", "AS")) |>
  sf::st_transform(crs = 4326)

water_sf <- counties_sf |>
  inner_join(water_2023_clean |> select(geoid, rate, plumbing, county, state),
             by = c("GEOID" = "geoid"))

water_sf_shifted  <- tigris::shift_geometry(water_sf)
states_sf_shifted <- tigris::shift_geometry(states_sf)

suppressWarnings({
  centroids <- water_sf_shifted |> sf::st_centroid() |>
    mutate(lon = sf::st_coordinates(geometry)[, 1],
           lat = sf::st_coordinates(geometry)[, 2]) |>
    sf::st_drop_geometry() |> as_tibble()
})

top10_c <- centroids |> slice_max(order_by = rate, n = 10)

ggplot() +
  geom_sf(data = states_sf_shifted,
          fill = "grey92", color = "white", linewidth = 0.35) +
  geom_point(data = centroids,
             aes(x = lon, y = lat, color = rate, size = plumbing),
             alpha = 0.6) +
  geom_point(data = top10_c, aes(x = lon, y = lat),
             shape = 21, color = "black", fill = NA,
             size = 5.5, stroke = 1.1) +
  ggrepel::geom_label_repel(data = top10_c,
                             aes(x = lon, y = lat, label = county),
                             size = 2.8, box.padding = 0.35,
                             max.overlaps = 20,
                             segment.color = "grey40") +
  scale_color_gradient(low = "#ffffcc", high = "#800026",
                       labels = scales::percent_format(),
                       name = "Rate") +
  scale_size_continuous(range = c(0.35, 6.5),
                        labels = scales::comma_format(),
                        name = "HH affected") +
  coord_sf() +
  labs(
    title    = "Plumbing Insecurity Across All 50 States (2023)",
    subtitle = "Ringed = top 10 worst · Alaska & Hawaii shown as insets · Dot size = households affected",
    caption  = SOURCE_CAPTION
  ) +
  theme_void(base_size = 10) +
  theme(plot.title    = element_text(face = "bold", hjust = 0.5, size = 13),
        plot.subtitle = element_text(color = "grey50", hjust = 0.5, size = 10),
